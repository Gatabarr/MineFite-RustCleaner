export global Theme {
    out property <color> bg-main: #120d1a;
    out property <color> bg-card: #1d1429;
    out property <color> accent: #8a2be2;
    out property <color> accent-hover: #9d4edd;
    out property <color> text-main: #e0e0e0;
    out property <color> text-dim: #8b8098;
    out property <color> danger: #ff4545;
    out property <color> success: #4caf50;
}